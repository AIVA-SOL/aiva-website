.env.local
.env.production
.env.development
*.env

# ============ Python 缓存 ============
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# ============ Python 虚拟环境 ============
venv/
.venv/
env/
ENV/

